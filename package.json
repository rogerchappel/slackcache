{
  "name": "slackcache",
  "version": "0.1.0",
  "description": "Local-first Slack archive cache, search, and thread viewer.",
  "type": "module",
  "bin": {
    "slackcache": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "pretest": "npm run build",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "slack",
    "archive",
    "search",
    "local-first",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
