{
  "name": "slackcache",
  "version": "0.1.0",
  "description": "Local-first Slack archive cache, search, and thread viewer.",
  "type": "module",
  "bin": {
    "slackcache": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "docs",
    "examples",
    "fixtures/sample",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "pretest": "npm run build",
    "package:smoke": "bash scripts/package-smoke.sh",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "slack",
    "archive",
    "search",
    "local-first",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/slackcache.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/slackcache/issues"
  },
  "homepage": "https://github.com/rogerchappel/slackcache#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
